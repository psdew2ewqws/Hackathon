{
  "name": "@taregak/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=../.env --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --env-file=../.env --test --import tsx 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ngeohash": "^0.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
