# Server-side secrets (never commit real values)
# Get yours at https://console.cloud.google.com -> APIs & Services -> Credentials
# Required APIs: Routes API, Places API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Server config
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Daily budget kill-switch (USD). When daily Routes API spend hits this, all
# new prediction requests fall back to cache-only mode with a notice.
DAILY_BUDGET_USD=20

# Mobile (public, OK to ship in app bundle)
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_token_here

# Backend URL the mobile app calls (use your LAN IP for device testing)
EXPO_PUBLIC_API_BASE=http://localhost:4000
