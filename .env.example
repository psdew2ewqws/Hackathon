# Copy to .env and adjust. Never commit .env.

# ─── Postgres (shared by P1/P2/P3) ────────────────────────────────────────────
POSTGRES_DB=traffic
POSTGRES_USER=traffic
POSTGRES_PASSWORD=change_me_locally
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── RTSP simulator (MediaMTX) ────────────────────────────────────────────────
RTSP_URL=rtsp://localhost:8554/site1
RTSP_TARGET_FPS=10
RTSP_TARGET_WIDTH=1920
RTSP_TARGET_HEIGHT=1080

# ─── Site identity (used by synth generators) ─────────────────────────────────
INTERSECTION_ID=SITE1

# ─── Data paths (override for non-default layouts) ────────────────────────────
DATA_DIR=data
RAW_VIDEO_DIR=data/raw/youtube
NORMALIZED_VIDEO_DIR=data/normalized
HISTORICAL_DIR=data/historical
DETECTOR_COUNTS_DIR=data/detector_counts
SIGNAL_LOGS_DIR=data/signal_logs
METADATA_DIR=data/metadata
ANNOTATIONS_DIR=data/annotations

# ─── CVAT (optional, profile=annotation) ──────────────────────────────────────
CVAT_HOST=http://localhost:8080
CVAT_USER=admin
CVAT_PASSWORD=change_me_locally
