{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://traffic-intel.local/schemas/intersection.schema.json",
  "title": "IntersectionSiteMetadata",
  "description": "Handbook §6.5 intersection metadata pack. Every field is required downstream by the Data Acquisition Layer, CV pipeline, or forecasting module.",
  "type": "object",
  "additionalProperties": false,
  "required": ["intersection_id", "camera", "approaches", "stop_lines", "monitoring_zones"],
  "properties": {
    "intersection_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]+$",
      "description": "Stable site identifier. Must match INTERSECTION_ID env var."
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "osm_node_id": { "type": "string" }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stream_url", "resolution", "fps", "fov_deg"],
      "properties": {
        "stream_url": { "type": "string", "format": "uri" },
        "resolution": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2, "maxItems": 2,
          "description": "[width, height] in pixels"
        },
        "fps": { "type": "integer", "minimum": 5, "maximum": 30 },
        "fov_deg": { "type": "number", "minimum": 10, "maximum": 180 },
        "mounting_height_m": { "type": "number", "minimum": 0 },
        "bearing_deg": {
          "type": "number", "minimum": 0, "maximum": 360,
          "description": "Compass bearing of the camera's optical axis"
        }
      }
    },
    "approaches": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "lanes"],
        "properties": {
          "name": { "enum": ["N", "S", "E", "W", "NE", "NW", "SE", "SW"] },
          "direction_bearing_deg": { "type": "number", "minimum": 0, "maximum": 360 },
          "lanes": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "type"],
              "properties": {
                "id": { "type": "string" },
                "type": { "enum": ["through", "left", "right", "shared", "bus", "bike"] },
                "detector_id": { "type": "string" },
                "width_m": { "type": "number", "minimum": 1.5, "maximum": 6.0 }
              }
            }
          }
        }
      }
    },
    "stop_lines": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["approach", "polyline_px"],
        "properties": {
          "approach": { "type": "string" },
          "polyline_px": {
            "type": "array", "minItems": 2,
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2, "maxItems": 2
            },
            "description": "Pixel coordinates [[x,y], ...] in the camera frame"
          }
        }
      }
    },
    "monitoring_zones": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "polygon_px"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "enum": ["queue_spillback", "approach_area", "conflict_zone", "ped_crossing"] },
          "polygon_px": {
            "type": "array", "minItems": 3,
            "items": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2, "maxItems": 2
            }
          }
        }
      }
    },
    "signal_plan_ref": {
      "type": "string",
      "description": "Path or URI pointing to the phase plan (e.g., configs/phase_plan.yml)"
    }
  }
}
